# Database / Storage Provider (csv or postgres)
STORAGE_PROVIDER=csv

# PostgreSQL Connection Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/exam_platform
PGHOST=localhost
PGPORT=5432
